# Environment variable NAMES only. Never add real values here.
# Copy to an untracked .env for local use; .env and .env.* are git-ignored.
#
# Never add a private key, mnemonic, seed phrase, or keystore password to any
# tracked file. Signing accounts are supplied to Foundry via --account (keystore);
# the repository and its tooling never hold key material.

# Sensitive provider configuration. Keep only in an untracked .env or the shell.
# MAINNET_RPC_URL is used for a production deployment; SEPOLIA_RPC_URL for a rehearsal.
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=

# Non-secret deployment arguments consumed by script/DeployMigrateRepV2Token.s.sol.
# MREP2_DISTRIBUTOR:   the sole address permitted to distribute or finalize.
# MREP2_RECIPIENT_CAP: the maximum number of unique initial recipients.
MREP2_DISTRIBUTOR=
MREP2_RECIPIENT_CAP=
